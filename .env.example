# ============================================================
# Portal MEIguia — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local no repositório
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Encontre em: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de serviço — NUNCA expor no cliente, apenas no servidor
# Encontre em: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ───────────────────────────────────────────────────
# Encontre em: Stripe Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret — gerado ao criar o webhook no Stripe Dashboard
# Stripe Dashboard → Developers → Webhooks → seu endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ID do preço do plano Pro (R$ 14,90/mês)
# Stripe Dashboard → Products → Plano Pro → Price ID
STRIPE_PRO_PRICE_ID=price_...

# ── Resend (e-mails transacionais) ──────────────────────────
# Crie uma conta em resend.com, verifique seu domínio e gere a API key
RESEND_API_KEY=re_...

# ── Cron Job ─────────────────────────────────────────────────
# String aleatória para proteger o endpoint /api/cron/alertas
# Gere com: openssl rand -hex 32
CRON_SECRET=seu_secret_aqui

# ── Abacatepay (PIX — plano Pro) ─────────────────────────────
# Crie uma conta em abacatepay.com e gere a API key
ABACATEPAY_API_KEY=...
# Token secreto para validar webhooks — gere com: openssl rand -hex 32
# Configure em: Abacatepay Dashboard → Webhooks → Secret
ABACATEPAY_WEBHOOK_SECRET=seu_secret_aqui

# ── Z-API (alertas WhatsApp — plano Premium) ──────────────────
# Crie uma instância em z-api.io e copie as credenciais
ZAPI_INSTANCE_ID=sua_instance_id
ZAPI_TOKEN=seu_token
ZAPI_CLIENT_TOKEN=seu_client_token

# ── Upstash Redis (rate limiting) ─────────────────────────────
# Crie um banco em upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ── App ──────────────────────────────────────────────────────
# URL pública da aplicação (sem trailing slash)
# Em desenvolvimento: http://localhost:3000
# Em produção: https://portal-meiguia-six.vercel.app
NEXT_PUBLIC_APP_URL=https://portal-meiguia-six.vercel.app
